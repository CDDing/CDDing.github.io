---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('log');

  const tagSet = new Set<string>();
  entries.forEach((entry) => {
    entry.data.tags.forEach((tag: string) => {
      tagSet.add(tag);
      tagSet.add(tag.split('/')[0]);
    });
  });

  return [...tagSet].map((tag) => ({
    params: { tag },
    props: { tag },
  }));
}

const { tag } = Astro.props;
const entries = await getCollection('log');
const isCategory = !tag.includes('/');

const filtered = entries.filter((entry) =>
  entry.data.tags.some((t: string) =>
    isCategory ? t.startsWith(tag + '/') || t === tag : t === tag
  )
);

const sorted = filtered.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const subTags = isCategory
  ? [...new Set(
      entries
        .flatMap((n) => n.data.tags)
        .filter((t: string) => t.startsWith(tag + '/'))
    )].sort()
  : [];

function countQA(body: string): number {
  return (body.match(/^## /gm) || []).length;
}

function countByTag(t: string): number {
  return entries.filter((n) => n.data.tags.includes(t)).length;
}
---

<StarlightPage frontmatter={{ title: `#${tag}`, description: `${tag} 태그 로그 목록` }}>
  {isCategory && subTags.length > 0 && (
    <div class="tag-filters">
      {subTags.map((st) => (
        <a href={`/log/tags/${st}/`} class="tag-filter">
          {st.split('/')[1]} ({countByTag(st)})
        </a>
      ))}
    </div>
  )}

  <div class="notes-grid">
    {sorted.map((entry) => {
      const qaCount = countQA(entry.body ?? '');
      const dateStr = entry.data.date.toISOString().slice(0, 10);
      return (
        <a href={`/log/${entry.id}/`} class="note-card">
          <h3 class="note-card-title">{entry.data.title}</h3>
          <div class="note-card-tags">
            {entry.data.tags.map((t: string) => {
              const category = t.split('/')[0];
              return <span class={`note-tag badge-${category}`}>#{t}</span>;
            })}
          </div>
          <span class="note-card-info">
            Q&A {qaCount}개 · {dateStr}
          </span>
        </a>
      );
    })}
  </div>

  <p style="margin-top: 24px;">
    <a href="/log/">← 전체 로그</a>
  </p>
</StarlightPage>
