---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="페이지를 찾을 수 없습니다 · CDDing" canonical={null}>
  <div class="shell notfound">
    <h1>페이지를 찾을 수 없습니다</h1>
    <p>
      이 사이트는 2026년 7월에 주소 구조가 바뀌었습니다.
      예전 주소는 더 이상 동작하지 않습니다.
    </p>
    <p class="links">
      <a href="/">전체 글 보기</a> · <a href="/series/">시리즈 보기</a>
    </p>
  </div>
</BaseLayout>

<style>
  .notfound {
    padding: 64px 20px 0;
  }
  .notfound h1 {
    margin: 0 0 14px;
    color: var(--heading);
    font-size: 1.5rem;
    font-weight: 720;
    letter-spacing: -0.03em;
  }
  .notfound p {
    margin: 0 0 12px;
    color: var(--text);
    line-height: 1.8;
    max-width: 52ch;
  }
  .links a {
    color: var(--accent-strong);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
