---
import type { CollectionEntry } from 'astro:content';
import { getSeriesId, formatKstDate } from '../lib/posts';
import { getSeriesMeta } from '../data/series';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const seriesId = getSeriesId(post.id);
const seriesTitle = seriesId ? getSeriesMeta(seriesId).title : null;
const dateStr = formatKstDate(post.data.date);
---

<article class="item" data-tags={post.data.tags.join(',')}>
  {seriesId && <a class="series" href={`/series/${seriesId}/`}>{seriesTitle}</a>}
  <h2 class="title">
    <a href={`/posts/${post.id}/`}>{post.data.title}</a>
  </h2>
  <p class="summary">{post.data.summary}</p>
  <div class="meta">
    {post.data.tags.map((tag) => (
      <a class="tag" href={`/tags/${tag}/`}>#{tag}</a>
    ))}
    <time class="date" datetime={post.data.date.toISOString()}>{dateStr}</time>
  </div>
</article>

<style>
  .item {
    padding: 20px 0;
    border-bottom: 1px solid var(--divider);
  }
  .series {
    color: var(--accent-strong);
    font-size: 0.78rem;
    font-weight: 600;
  }
  .series:hover {
    text-decoration: underline;
  }
  .title {
    margin: 3px 0 6px;
    font-size: var(--text-list-title);
    font-weight: 640;
    letter-spacing: -0.021em;
    line-height: 1.4;
  }
  .title a {
    display: block;
    color: var(--heading);
  }
  .title a:hover {
    color: var(--accent-strong);
  }
  .summary {
    margin: 0 0 10px;
    color: var(--text);
    font-size: 0.88rem;
    line-height: 1.65;
  }
  .meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px;
  }
  .tag {
    border: 1px solid var(--border);
    border-radius: 20px;
    color: var(--text-muted);
    font-size: var(--text-tag);
    padding: 2px 10px;
  }
  .tag:hover {
    background: var(--accent-bg);
    border-color: var(--accent-border);
    color: var(--accent-strong);
  }
  .date {
    margin-left: auto;
    color: var(--text-faint);
    font-size: 0.76rem;
  }
</style>
